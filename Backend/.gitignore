# Python Virtual Environments (The folder with libraries)
env/
venv/
ENV/

# Python Cache (Compiled code generated by Python)
__pycache__/
*.py[cod]
*$py.class

# Secrets and Credentials (VERY IMPORTANT)
.env

# Database (Safety net for local SQLite files)
*.sqlite3

# Media and Static (User-uploaded files)
media/
static/

# OS specific files
.DS_Store
Thumbs.db

# IDE specific files
.vscode/
.idea/